{
  "version": 1,
  "description": "Inject the mcp router skill into context at session start.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
